{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "unity": {
      "type": "local",
      "command": ["/absolute/path/to/unity-mcp/server/bin/unity-mcp"],
      "enabled": true,
      "environment": {
        "UNITY_MCP_WS_HOST": "127.0.0.1",
        "UNITY_MCP_WS_PORT": "8081",
        "UNITY_MCP_WS_PATH": "/ws"
      },
      "timeout": 30000
    }
  }
}
